# Cấu hình cho Meeting Minutes Lite
# Copy file này thành .env và điền thông tin thực tế khi chạy

# 1. URL của Whisper/STT Server (bắt buộc)
# Mặc định: http://localhost:8178 (chạy local bằng whisper/service.py)
WHISPER_SERVER_URL=http://localhost:8178

# 2. Cấu hình LLM cho tính năng Summary (AI Tóm tắt)
# Mặc định kết nối tới Local Ollama. 
# Nếu dùng Viettel Netmind, hãy đổi URL và API KEY tương ứng.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=not-needed
LLM_MODEL=qwen2.5:72b
